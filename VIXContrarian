def main():
    parser = argparse.ArgumentParser(
        description="SVXY / VIX spike mean-reversion backtest + visualization")
    parser.add_argument("--source",   default="yfinance",
                        choices=["polygon", "alpaca", "yfinance"])
    parser.add_argument("--key",      default=None,
                        help="API key (Polygon or Alpaca)")
    parser.add_argument("--secret",   default=None,
                        help="API secret (Alpaca only)")
    parser.add_argument("--thresh",   type=float, default=VIX_THRESH,
                        help=f"VIX entry threshold (default {VIX_THRESH})")
    parser.add_argument("--exit-vix", type=float, default=EXIT_VIX,
                        help=f"VIX exit level (default {EXIT_VIX})")
    parser.add_argument("--no-plot",  action="store_true",
                        help="Skip chart rendering (headless servers)")
    parser.add_argument("--save-png", default="",
                        help="Custom output path for chart PNG")
    args = parser.parse_args([])   # uses defaults; swap to parse_args()
                                   # to accept CLI flags

    print("=" * 62)
    print("  SVXY / VIX Spike Backtest")
    print(f"  Period     : {START_DATE}  to  {END_DATE}")
    print(f"  Entry      : Day after VIX closes >= {args.thresh}")
    print(f"  Exit       : VIX first closes < {args.exit_vix}"
          f"  (hard stop {MAX_HOLD}d)")
    print(f"  Capital    : ${INITIAL_CAP:,}  (100% in per trade)")
    print(f"  Data source: {args.source}")
    print("=" * 62)

    vix, svxy = load_data(args.source, args)

    episodes = find_spike_episodes(vix)
    print(f"\nSpike episodes detected: {len(episodes)}")
    for i in episodes:
        print(f"  {vix.index[i].strftime('%Y-%m-%d')}  VIX = {vix.iloc[i]:.1f}")

    results = run_backtest(vix, svxy, episodes)
    print_results(results)

    csv_path = (f"svxy_backtest_{args.source}_"
                f"{datetime.today().strftime('%Y%m%d')}.csv")
    results.to_csv(csv_path, index=False)
    print(f"\n  Trade log saved -> {csv_path}")

    if not args.no_plot:
        plot_results(vix, svxy, results, episodes,
                     save_path=args.save_png)


if __name__ == "__main__":
    main()
